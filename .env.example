WAQI_TOKEN=
GEMINI_API_KEY=
NASA_FIRMS_KEY=

# ── Qwen 3.0 ────────────────────────────────────────────────────────────────
# # Option A – Alibaba DashScope (direct, cheapest)
# QWEN_API_KEY=<your-dashscope-key-here>
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# # Option B – OpenRouter (if you already have an account there)
# QWEN_API_KEY=<your-openrouter-key-here>
# QWEN_API_BASE=https://openrouter.ai/api/v1
# Option C – Local Ollama (best for development, no rate limits, but requires local setup)
# QWEN_API_KEY=ollama
# QWEN_API_BASE=http://localhost:11434/v1

# ── Provider switches ────────────────────────────────────────────────────────
# LLM_TEXT_PROVIDER=qwen
# LLM_FUNCTION_CALLER=qwen

# ── Model selection ──────────────────────────────────────────────────────────
# # Best quality (Qwen3 235B MoE):
# QWEN_TEXT_MODEL=qwen3-235b-a22b
# QWEN_FUNCTION_CALLER_MODEL=qwen3-235b-a22b
# Local
# QWEN_TEXT_MODEL=qwen2.5:72b
# QWEN_FUNCTION_CALLER_MODEL=qwen2.5:72b